{
  "name": "@gladysassistant/integration-store",
  "version": "1.0.0",
  "description": "Automated indexer of the decentralized Gladys Assistant integration store: crawls the `gladys-assistant-integration` GitHub topic, validates manifests, and publishes a static index.json on GitHub Pages.",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GladysAssistant/integration-store.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build-index": "node src/cli.js",
    "generate-placeholder-cover": "node scripts/generate-placeholder-cover.js",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "test": "mocha",
    "coverage": "c8 --reporter=text --reporter=lcov --check-coverage --lines 100 --functions 100 --statements 100 --branches 100 mocha"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "image-size": "^2.0.2",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "c8": "^10.1.3",
    "chai": "^5.2.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.3.0",
    "mocha": "^11.7.0",
    "prettier": "^3.6.2"
  }
}
